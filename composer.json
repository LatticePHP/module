{
    "name": "lattice/module",
    "description": "Module system and dependency injection for LatticePHP",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "lattice/contracts": "dev-main",
        "lattice/compiler": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Module\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Module\\Tests\\": "tests/"
        }
    }
}
