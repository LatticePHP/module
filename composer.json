{
    "name": "lattice/module",
    "description": "Module system and dependency injection for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "module",
        "dependency-injection",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/module"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "lattice/compiler": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Module\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Module\\Tests\\": "tests/"
        }
    }
}
